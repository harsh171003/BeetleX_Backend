generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  participant
  judge
  organizer
  admin
}

enum EventStatus {
  draft
  open
  active
  judging
  closed
}

enum MemberRole {
  leader
  member
}

enum RegistrationStatus {
  pending
  confirmed
  cancelled
  waitlisted
}

enum ProjectStatus {
  draft
  submitted
  under_review
  scored
}

enum AnnouncementPriority {
  info
  warning
  urgent
}

enum AnnouncementTarget {
  all
  participants
  judges
  organizers
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String
  fullName      String
  username      String   @unique
  avatarUrl     String?
  bio           String?
  githubUrl     String?
  linkedinUrl   String?
  role          UserRole @default(participant)
  isVerified    Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastLoginAt   DateTime?

  events        Event[]
  registrations Registration[]
}

model Event {
  id                  String      @id @default(uuid())
  slug                String      @unique
  title               String
  description         String
  bannerUrl           String?
  organizerId         String
  status              EventStatus @default(draft)

  maxTeamSize         Int @default(4)
  minTeamSize         Int @default(1)

  maxRegistrations    Int?

  registrationOpen    DateTime
  registrationClose   DateTime

  eventStart          DateTime
  eventEnd            DateTime

  submissionDeadline  DateTime

  timezone            String
  prizePool           Json?
  tags                String[]

  isPublic            Boolean @default(true)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organizer           User @relation(fields: [organizerId], references: [id])

  teams               Team[]
  registrations       Registration[]
  projects            Project[]
  announcements       Announcement[]
}
model Team {
  id          String   @id @default(uuid())
  eventId     String
  name        String
  inviteCode  String   @unique
  leaderId    String
  track       String?
  isOpen      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event       Event @relation(fields: [eventId], references: [id])

  @@unique([eventId, name])
}

model TeamMember {
  teamId    String
  userId    String
  role      MemberRole
  joinedAt  DateTime @default(now())

  @@id([teamId, userId])
}

model Registration {
  id                String @id @default(uuid())
  eventId           String
  userId            String
  teamId            String?

  status            RegistrationStatus @default(pending)

  registrationData  Json?

  registeredAt      DateTime @default(now())
  confirmedAt       DateTime?
  cancelledAt       DateTime?

  event             Event @relation(fields: [eventId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
}

model Project {
  id            String @id @default(uuid())

  eventId       String
  teamId        String

  title         String
  description   String

  techStack     String[]

  demoUrl       String?
  repoUrl       String?
  deckUrl       String?
  videoUrl      String?

  status        ProjectStatus @default(draft)

  submittedAt   DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  event         Event @relation(fields: [eventId], references: [id])

  @@unique([eventId, teamId])
}

model EventJudge {
  id          String @id @default(uuid())

  eventId     String
  judgeId     String

  track       String?

  assignedAt  DateTime @default(now())
  assignedBy  String
}

model Score {
  id            String @id @default(uuid())

  projectId     String
  judgeId       String

  innovation    Int
  technical     Int
  impact        Int
  presentation  Int

  comments      String?

  submittedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([projectId, judgeId])
}

model Announcement {
  id            String @id @default(uuid())

  eventId       String
  authorId      String

  title         String
  body          String

  priority      AnnouncementPriority @default(info)
  target        AnnouncementTarget @default(all)

  isPublished   Boolean @default(false)

  publishedAt   DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  event         Event @relation(fields: [eventId], references: [id])
}

model AnnouncementRead {
  announcementId String
  userId         String
  readAt         DateTime @default(now())

  @@id([announcementId, userId])
}